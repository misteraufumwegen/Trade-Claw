# =====================================================
# TRADING BOT - Environment Configuration Template
# =====================================================
# Copy this file to .env and update values for local development
# NEVER commit .env to version control

# =====================================================
# APPLICATION
# =====================================================
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=trading_user
DB_PASSWORD=trading_password
DB_NAME=trading_bot
DATABASE_URL=postgresql+asyncpg://trading_user:trading_password@postgres:5432/trading_bot

# =====================================================
# REDIS
# =====================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# =====================================================
# API SERVER
# =====================================================
API_HOST=0.0.0.0
API_PORT=8000

# =====================================================
# ENCRYPTION (for credentials vault)
# =====================================================
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# =====================================================
# BROKER CREDENTIALS (SANDBOX/DEMO - Safe for Testing)
# =====================================================

# ALPACA (Sandbox)
ALPACA_API_KEY=your-alpaca-sandbox-key
ALPACA_API_SECRET=your-alpaca-sandbox-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Paper trading
ALPACA_ENVIRONMENT=sandbox

# OANDA (Demo Account)
OANDA_API_KEY=your-oanda-demo-key
OANDA_ACCOUNT_ID=your-oanda-demo-account-id
OANDA_BASE_URL=https://api-fxpractice.oanda.com  # Practice/demo
OANDA_ENVIRONMENT=demo

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# =====================================================
# CORS (for frontend development)
# =====================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =====================================================
# JWT (Authentication)
# =====================================================
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =====================================================
# OPTIONAL: Third-party Services
# =====================================================
# Sentry (error tracking)
SENTRY_DSN=

# Slack (notifications)
SLACK_WEBHOOK_URL=

# Email (for alerts)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
