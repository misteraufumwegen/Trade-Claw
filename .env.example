# =====================================================
# Trade-Claw — Environment Configuration Template
# =====================================================
# Copy this file to `.env` and fill in REAL values.
# NEVER commit `.env` to version control.
#
# Quick setup:
#   cp .env.example .env                                       # macOS/Linux
#   copy .env.example .env                                     # Windows
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"   # TRADE_CLAW_API_KEY
#   python -c "import secrets; print(secrets.token_urlsafe(32))"   # SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # ENCRYPTION_KEY

# =====================================================
# APPLICATION
# =====================================================
# ENVIRONMENT must be one of: development | test | production
# In non-development mode the app refuses to start if any required secret is
# missing or still uses a placeholder value (see app/security/settings.py).
ENVIRONMENT=development

# REQUIRED in production — any reasonably long random string.
SECRET_KEY=

# REQUIRED — API key passed as either `Authorization: Bearer <key>` or
# `X-API-Key: <key>` on all /api/v1/* endpoints.
TRADE_CLAW_API_KEY=dev-api-key-local-only

# REQUIRED — Fernet key for the broker-credentials vault.
ENCRYPTION_KEY=

# =====================================================
# DATABASE
# =====================================================
# SQLite by default — a file in the project root. Override with any
# SQLAlchemy URL (e.g. postgresql+psycopg://user:pw@host/db) if you migrate.
DATABASE_URL=sqlite:///./trade_claw.db

# =====================================================
# API SERVER
# =====================================================
API_HOST=127.0.0.1
API_PORT=8000

# Comma-separated list, e.g. http://localhost:3000,http://localhost:8080
# Leave empty when the frontend is served from the same origin (default).
CORS_ORIGINS=

# =====================================================
# ML GATE
# =====================================================
# off | advisory (default) | enforce
ML_GATE_MODE=advisory
ML_THRESHOLD=0.5

# =====================================================
# AUTOPILOT
# =====================================================
# Constant-time-compared against the path segment of
# /api/v1/webhook/tradingview/{secret}. Leave empty to disable the webhook.
TV_WEBHOOK_SECRET=

# How often the lifespan-task polls open TradeOutcome rows for resolution.
OUTCOME_POLL_SECONDS=2

# =====================================================
# SAFETY GATES
# =====================================================
# Hard cap on stop-loss distance from entry, as a percentage. Orders whose
# (entry - sl) / entry exceeds this are rejected by the risk engine.
MAX_SL_DISTANCE_PCT=5.0

# Consecutive-loss cooldown. After this many WIN/LOSS rows resolve to LOSS
# in a row, the risk engine and TradingView webhook reject new submits for
# COOLDOWN_MINUTES. A single WIN resets the counter.
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES=60

# Autopilot dry_run → live transition requires at least this many would-submit
# decisions recorded in dry_run mode first. Override with `force: true` on the
# /api/v1/autopilot endpoint when you accept the risk.
MIN_DRY_RUN_TRADES=20

# Optional TradingView webhook IP allowlist (CSV). Leave empty to allow all
# (preserves prior behaviour). When set, requests are matched against the
# real client IP (Cloudflare-tunnel-aware via CF-Connecting-IP).
# Documented TradingView outbound IPs (verify against TV docs before relying):
#   52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
TV_ALLOWED_IPS=

# =====================================================
# MACRO EVENT FEEDS (GDELT + GDACS, both free, no auth)
# =====================================================
# Set either to false to disable that source.
MACRO_GDELT_ENABLED=true
MACRO_GDACS_ENABLED=true

# Poll cadences. GDELT is news (chattier), GDACS is structured disasters (sparser).
MACRO_GDELT_POLL_SECONDS=90
MACRO_GDACS_POLL_SECONDS=300

# Multi-source confirmation gate for GDELT — fire a signal only when at least
# this many distinct domains report the same keyword pack inside the window.
MACRO_GDELT_MIN_DOMAINS=2
MACRO_GDELT_WINDOW_MINUTES=60

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=trade_claw.log
