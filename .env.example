# =====================================================
# Trade-Claw — Environment Configuration Template
# =====================================================
# Copy this file to `.env` and fill in REAL values.
# NEVER commit `.env` to version control.
#
# Quick setup:
#   cp .env.example .env
#   # Generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"   # TRADE_CLAW_API_KEY
#   python -c "import secrets; print(secrets.token_urlsafe(32))"   # SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # ENCRYPTION_KEY

# =====================================================
# APPLICATION
# =====================================================
# ENVIRONMENT must be one of: development | test | production
# In non-development mode the app refuses to start if any required secret is
# missing or still uses a placeholder value (see app/security/settings.py).
ENVIRONMENT=development
DEBUG=True

# REQUIRED in production — any reasonably long random string.
SECRET_KEY=

# REQUIRED — API key used as the Bearer token for all /api/v1/* endpoints.
# Single-user setup: set this once, pass via `Authorization: Bearer <key>`.
TRADE_CLAW_API_KEY=

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=trading_user
DB_PASSWORD=                          # REQUIRED — no default
DB_NAME=trading_bot
DATABASE_URL=postgresql+asyncpg://trading_user:REPLACE_ME@postgres:5432/trading_bot

# =====================================================
# REDIS
# =====================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# =====================================================
# API SERVER
# =====================================================
API_HOST=0.0.0.0
API_PORT=8000

# =====================================================
# ENCRYPTION (for credentials vault)
# =====================================================
# REQUIRED — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =====================================================
# BROKER CREDENTIALS
# Store these in the encrypted vault, not directly in env, whenever possible.
# =====================================================
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_BASE_URL=https://api-fxpractice.oanda.com     # use fxpractice for demo
OANDA_ENVIRONMENT=demo                               # demo | live

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=logs/trade_claw.log

# =====================================================
# CORS (frontend development)
# Comma-separated list, e.g.: http://localhost:3000,http://localhost:8080
# Leave empty to disable CORS entirely.
# =====================================================
CORS_ORIGINS=

# =====================================================
# OPTIONAL: Third-party Services
# =====================================================
SENTRY_DSN=
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
